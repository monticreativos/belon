---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
}

import "../styles/global.css";
import CookieConsent from "../components/CookieConsent.astro";
import { getLocaleFromPath, getPathForLocale, pathnameWithoutBase } from "../i18n/routes";
import FloatingConsultButton from "../components/FloatingConsultButton.astro";
import { seo, getCanonicalUrl, organization } from "../config/seo";

const { title = "Urbanismo | Consultoría Belón", description, canonical, noindex = false, ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base.slice(0, -1) : base;
const pathname = pathnameWithoutBase(Astro.url.pathname, base);
const locale = getLocaleFromPath(pathname);
const htmlLang = locale === "en" ? "en" : "es";

const esHref = basePath + getPathForLocale(pathname, "es");
const enHref = basePath + getPathForLocale(pathname, "en");
const origin = Astro.url.origin;

const metaDescription = description ?? (locale === "en" ? seo.defaultDescriptionEn : seo.defaultDescription);
const canonicalUrl = canonical ?? getCanonicalUrl(pathname);
const ogImageUrl = ogImage ?? seo.defaultOgImage;
const ogLocale = locale === "en" ? seo.localeEn : seo.localeEs;
const alternateLocale = locale === "en" ? seo.localeEs : seo.localeEn;

const jsonLdOrganization = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: organization.name,
  url: organization.url,
  logo: organization.logo,
  description: organization.description,
  address: organization.address,
  contactPoint: organization.contactPoint,
};

const jsonLdWebSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: seo.siteName,
  url: organization.url,
  publisher: { "@id": organization.url },
  inLanguage: [htmlLang === "es" ? "es" : "en"],
};
---

<html lang={htmlLang} data-base={basePath}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <>
        <link rel="canonical" href={canonicalUrl} />
        <meta name="robots" content="index, follow" />
      </>
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={alternateLocale} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- hreflang (x-default = español) -->
    <link rel="alternate" hreflang="x-default" href={`${origin}${esHref}`} />
    <link rel="alternate" hreflang="es" href={`${origin}${esHref}`} />
    <link rel="alternate" hreflang="en" href={`${origin}${enHref}`} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdOrganization)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdWebSite)} />

    <!-- Sitemap discovery -->
    <link rel="sitemap" type="application/xml" href={`${origin}${basePath}/sitemap-index.xml`} />

    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700,0..1&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    />
    <link rel="icon" type="image/png" href={`${basePath}/img/favicon.png`} />

    <style>
      body {
        font-family: "Open Sans", system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      .glass-effect {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(8px);
      }
    </style>
    <script is:inline>
      (() => {
        try {
          var basePath = document.documentElement.getAttribute("data-base") || "";
          var pathname = window.location.pathname;
          var path = basePath && pathname.indexOf(basePath) === 0
            ? (pathname.slice(basePath.length) || "/")
            : pathname;

          var storedLang = localStorage.getItem("preferred-language");

          if (storedLang === "en" && path !== "/en" && path.indexOf("/en/") !== 0) {
            var mapEsToEn = {
              "/": "/en/",
              "/urbanismo": "/en/urban-planning",
              "/gestion-patrimonial": "/en/property-management",
              "/valoraciones": "/en/property-valuations",
              "/recursos-administrativos": "/en/administrative-law",
              "/contacto": "/en/contact"
            };
            var target = mapEsToEn[path];
            if (target) {
              window.location.replace(basePath + target);
              return;
            }
          }

          if (storedLang === "es" && (path === "/en" || path.indexOf("/en/") === 0)) {
            var mapEnToEs = {
              "/en/": "/",
              "/en/urban-planning": "/urbanismo",
              "/en/property-management": "/gestion-patrimonial",
              "/en/property-valuations": "/valoraciones",
              "/en/administrative-law": "/recursos-administrativos",
              "/en/contact": "/contacto"
            };
            var target = mapEnToEs[path];
            if (target) {
              window.location.replace(basePath + target);
              return;
            }
          }

          const stored = localStorage.getItem("theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const isDark = stored === "dark" || (!stored && prefersDark);
          if (isDark) {
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.classList.remove("dark");
          }
        } catch (e) {
          console.error(e);
        }
      })();
    </script>
  </head>
  <body
    class="bg-background-light text-neutral-500 antialiased dark:bg-background-dark dark:text-slate-100 transition-colors duration-300"
  >
    <div class="relative flex min-h-screen flex-col" id="page-root">
      <slot />
    </div>

    <CookieConsent />
    <FloatingConsultButton />

    <script is:inline>
      (() => {
        if (typeof window === "undefined") return;

        window.addEventListener("DOMContentLoaded", () => {
          // Toggle tema claro/oscuro
          const toggle = document.querySelector("[data-theme-toggle]");
          const root = document.documentElement;

          const applyTheme = (mode) => {
            if (mode === "dark") {
              root.classList.add("dark");
            } else {
              root.classList.remove("dark");
            }
          };

          if (toggle) {
            toggle.addEventListener("click", () => {
              const isDark = root.classList.contains("dark");
              const next = isDark ? "light" : "dark";
              applyTheme(next);
              try {
                localStorage.setItem("theme", next);
              } catch (e) {
                console.error(e);
              }
            });
          }

          // Navbar animada al hacer scroll
          const nav = document.querySelector('nav[data-nav="main"]');
          if (nav) {
            const onScroll = () => {
              if (window.scrollY > 10) {
                nav.classList.add("nav-scrolled");
              } else {
                nav.classList.remove("nav-scrolled");
              }
            };
            onScroll();
            window.addEventListener("scroll", onScroll, { passive: true });
          }

          // Animaciones por scroll
          const applyScrollAnimations = () => {
            const elements = document.querySelectorAll(
              ".section-animate, .section-animate-delayed, .card-animate"
            );

            if ("IntersectionObserver" in window) {
              const observer = new IntersectionObserver(
                (entries) => {
                  entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                      entry.target.classList.add("in-view");
                      observer.unobserve(entry.target);
                    }
                  });
                },
                {
                  threshold: 0.18,
                }
              );

              elements.forEach((el) => observer.observe(el));
            } else {
              elements.forEach((el) => el.classList.add("in-view"));
            }
          };

          applyScrollAnimations();

          // Modal de solicitud de consulta (navbar + botón flotante)
          const openContactButtons =
            document.querySelectorAll("[data-open-contact-modal]");
          const contactModal = document.getElementById("quick-contact-modal");

          if (contactModal && openContactButtons.length) {
            const closeBtn = contactModal.querySelector("[data-close-contact-modal]");
            const overlay = contactModal;

            const openModal = () => {
              contactModal.classList.remove("hidden");
              contactModal.classList.add("flex");
            };

            const closeModal = () => {
              contactModal.classList.add("hidden");
              contactModal.classList.remove("flex");
            };

            openContactButtons.forEach((btn) => {
              btn.addEventListener("click", (ev) => {
                ev.preventDefault();
                openModal();
              });
            });

            if (closeBtn) {
              closeBtn.addEventListener("click", (ev) => {
                ev.preventDefault();
                closeModal();
              });
            }

            overlay.addEventListener("click", (event) => {
              if (event.target === overlay) {
                closeModal();
              }
            });
          }
        });
      })();
    </script>

    <!-- Modal global de solicitud de consulta rápida -->
    <div
      id="quick-contact-modal"
      class="fixed inset-0 z-[60] hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm"
    >
      <div
        class="mx-4 w-full max-w-2xl rounded-2xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700 shadow-2xl shadow-slate-900/40 p-6 sm:p-7 relative"
      >
        <button
          type="button"
          class="absolute right-4 top-4 inline-flex size-8 items-center justify-center rounded-full border border-slate-200/80 dark:border-slate-700 text-slate-400 hover:text-slate-600 dark:hover:text-slate-100 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
          data-close-contact-modal
          aria-label="Cerrar"
        >
          <span class="material-symbols-outlined text-base">close</span>
        </button>

        <header class="mb-4">
          <p class="text-xs font-bold uppercase tracking-[0.25em] text-primary mb-1">
            Solicitar consulta
          </p>
          <h2 class="text-xl sm:text-2xl font-black text-neutral-700 dark:text-slate-50">
            Cuéntenos brevemente su caso
          </h2>
          <p class="text-sm text-neutral-500 dark:text-slate-300 mt-1">
            Le responderemos con la mayor brevedad posible para concertar una primera
            consulta.
          </p>
        </header>

        <form class="space-y-4" method="post">
          <div class="space-y-1.5">
            <label
              for="modal-nombre"
              class="block text-xs font-semibold text-neutral-600 dark:text-slate-100"
              >Nombre completo</label
            >
            <input
              id="modal-nombre"
              name="nombre"
              type="text"
              required
              autocomplete="name"
              class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2.5 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="Nombre y apellidos"
            />
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label
                for="modal-email"
                class="block text-xs font-semibold text-neutral-600 dark:text-slate-100"
                >Email</label
              >
              <input
                id="modal-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2.5 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                placeholder="su@email.com"
              />
            </div>
            <div class="space-y-1.5">
              <label
                for="modal-telefono"
                class="block text-xs font-semibold text-neutral-600 dark:text-slate-100"
                >Teléfono</label
              >
              <input
                id="modal-telefono"
                name="telefono"
                type="tel"
                autocomplete="tel"
                pattern="[\d\s+()-]{6,}"
                class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2.5 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                placeholder="+34 ..."
              />
            </div>
          </div>

          <div class="space-y-1.5">
            <label
              for="modal-tipo"
              class="block text-xs font-semibold text-neutral-600 dark:text-slate-100"
              >Tipo de consulta</label
            >
            <select
              id="modal-tipo"
              name="tipo"
              required
              class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2.5 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
            >
              <option value="">Seleccione una opción</option>
              <option value="urbanismo">Urbanismo</option>
              <option value="valoraciones">Valoraciones inmobiliarias</option>
              <option value="patrimonio">Gestión patrimonial</option>
              <option value="recursos">Recursos administrativos</option>
              <option value="otro">Otro</option>
            </select>
          </div>

          <div class="space-y-1.5">
            <label
              for="modal-mensaje"
              class="block text-xs font-semibold text-neutral-600 dark:text-slate-100"
              >Mensaje</label
            >
            <textarea
              id="modal-mensaje"
              name="mensaje"
              rows="4"
              required
              class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2.5 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary resize-none"
              placeholder="Describa brevemente su consulta..."
            ></textarea>
          </div>

          <div class="space-y-3 pt-1">
            <div class="flex items-start gap-2">
              <input
                id="modal-acepto-datos"
                name="acepto_datos"
                type="checkbox"
                required
                class="mt-0.5 size-4 rounded border-slate-300 text-primary focus:ring-primary"
              />
              <label
                for="modal-acepto-datos"
                class="text-xs text-neutral-500 dark:text-slate-300"
              >
                He leído y acepto la
                <a
                  href={`${basePath}/politica-privacidad`}
                  class="underline underline-offset-2 decoration-primary/70 hover:text-primary"
                  >política de privacidad</a
                >
                y el tratamiento de mis datos para gestionar mi consulta.
              </label>
            </div>
            <div class="flex items-start gap-2">
              <input
                id="modal-newsletter"
                name="newsletter"
                type="checkbox"
                class="mt-0.5 size-4 rounded border-slate-300 text-primary focus:ring-primary"
              />
              <label
                for="modal-newsletter"
                class="text-xs text-neutral-500 dark:text-slate-300"
              >
                Acepto recibir información relevante y actualizaciones sobre servicios de
                Consultoría Belón. Podrá darse de baja en cualquier momento.
              </label>
            </div>
          </div>

          <div
            class="mt-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
          >
            <p class="text-[11px] text-neutral-400 dark:text-slate-500">
              Sus datos no se cederán a terceros salvo obligación legal. Consulte la
              política de privacidad para más detalle.
            </p>
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-full bg-primary px-7 py-3 text-xs font-black tracking-[0.25em] uppercase text-white shadow-md shadow-primary/40 hover:bg-primary/90 hover:-translate-y-0.5 transition-all"
            >
              Enviar consulta
            </button>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>