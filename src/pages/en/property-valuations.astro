---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ServiceModal from "../../components/ServiceModal.astro";
---

<BaseLayout title="Property valuations | Consultoría Belón">
  <Navbar />

  <main>
    <!-- Hero -->
    <section
      class="section-animate relative bg-white dark:bg-background-dark py-20 lg:py-24 overflow-hidden"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(0,141,210,0.22),transparent_70%)]"
      ></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-[0.2em] uppercase mb-5"
          >
            <span class="material-symbols-outlined text-sm">analytics</span>
            Valuations and appraisals
          </div>
          <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-600 dark:text-slate-50 leading-[1.05] mb-6"
          >
            Property
            <span class="text-primary">valuations and appraisals</span>
          </h1>
          <p class="text-lg text-neutral-500 dark:text-slate-300 max-w-2xl mb-4">
            Consultoría Belón prepares valuations of residential, commercial, industrial
            and land assets, as well as complex properties and real estate rights.
          </p>
          <p class="text-sm text-neutral-500 dark:text-slate-300 max-w-2xl mb-3">
            Valuations can be carried out for many purposes: purchases and sales,
            inheritances, separations, tax valuations, claims against public authorities
            or investment analysis.
          </p>
          <p class="text-sm text-neutral-500 dark:text-slate-300 max-w-2xl">
            Our team has wide experience in court valuations, expropriations and
            contradictory expert valuations against the Tax Administration and Cadastre.
          </p>
        </div>
      </div>
    </section>

    <!-- Services grid -->
    <section class="section-animate-delayed py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-12">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Valuation services
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Our main lines of work in valuations and appraisals. Click each card to see
            the details of the service.
          </p>
        </header>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <ServiceCard
            id="tasaciones-inmobiliarias"
            icon="home_work"
            title="Real estate valuations"
            description="Professional valuation of all types of properties and associated real rights."
          />
          <ServiceCard
            id="tasacion-pericial"
            icon="balance"
            title="Contradictory expert valuation"
            description="Defence against tax value assessments through an independent expert valuation."
          />
          <ServiceCard
            id="peritacion-judicial"
            icon="gavel"
            title="Court expert reports"
            description="Expert reports for court proceedings involving real estate."
          />
          <ServiceCard
            id="valoraciones-fiscales"
            icon="request_quote"
            title="Tax valuations and savings"
            description="Value analysis to reduce tax burdens when a property is overvalued."
          />
          <ServiceCard
            id="operaciones-vinculadas"
            icon="sync_alt"
            title="Related-party transactions"
            description="Justification of market value in transactions between related parties."
          />
          <ServiceCard
            id="inventario-bienes"
            icon="inventory_2"
            title="Asset inventories"
            description="Updated inventories of real estate assets for companies and public bodies."
          />
          <ServiceCard
            id="adm-local"
            icon="apartment"
            title="Valuations for local authorities"
            description="Reports for administrative files and supplementary tax assessments."
          />
          <ServiceCard
            id="analisis-inversiones"
            icon="insights"
            title="Investment analysis"
            description="Feasibility and profitability studies to support investment decisions."
          />
        </div>
      </div>
    </section>

    <!-- Modals -->
    <ServiceModal id="tasaciones-inmobiliarias" title="Real estate valuations">
      <p>
        We carry out valuations of all kinds of real estate assets, adapting the
        methodology to the nature of the asset and the purpose of the report.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Types of property
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Dwellings.</li>
        <li>Retail premises and offices.</li>
        <li>Parking spaces and storage rooms.</li>
        <li>Industrial buildings.</li>
        <li>Rural properties.</li>
        <li>Plots and development land.</li>
        <li>Special properties such as hotels, clinics or care homes.</li>
      </ul>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Rights and special situations
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Usufruct and bare ownership.</li>
        <li>Easements and administrative concessions.</li>
        <li>Surface rights.</li>
        <li>
          Assessment of damages, compensation, repairs or specific building elements.
        </li>
      </ul>
    </ServiceModal>

    <ServiceModal id="tasacion-pericial" title="Contradictory expert valuation">
      <p>
        We support clients who have received a value assessment from the Tax
        Administration and believe that the value assigned to their property is
        excessive.
      </p>
      <p>
        We analyse the valuation performed by the tax authorities and design a strategy to
        challenge it through a contradictory expert valuation.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Typical procedures
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Transfer Tax (ITP).</li>
        <li>Inheritance and Gift Tax.</li>
      </ul>
      <p>
        In many cases this procedure allows a significant reduction in the taxable base of
        the tax.
      </p>
    </ServiceModal>

    <ServiceModal id="peritacion-judicial" title="Court expert reports">
      <p>
        We prepare expert reports for court proceedings involving real estate, providing
        objective and well-founded valuations.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Typical cases
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Inheritance and estate partitioning.</li>
        <li>Divorces and separation of assets.</li>
        <li>Foreclosures and enforcement proceedings.</li>
        <li>Expropriations.</li>
        <li>Assessment of damages, compensations or contractual breaches.</li>
      </ul>
      <p>
        Our reports can be used as technical evidence in court and follow criteria
        recognised by the courts.
      </p>
    </ServiceModal>

    <ServiceModal
      id="valoraciones-fiscales"
      title="Tax valuations and tax savings"
    >
      <p>
        Many taxes can be challenged when the official value of a property is higher than
        its real market value or does not reflect its physical condition.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        We analyse cases related to
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Transfers between individuals or with companies.</li>
        <li>Inheritance and succession.</li>
        <li>Dissolution of co-ownership.</li>
        <li>Settlement of matrimonial property.</li>
      </ul>
      <p>
        If action is taken in time, it is often possible to reduce the tax burden
        significantly, supporting the claim with solid valuation reports.
      </p>
    </ServiceModal>

    <ServiceModal
      id="operaciones-vinculadas"
      title="Valuation for related-party transactions"
    >
      <p>
        Related-party transactions occur when there are dealings between connected
        companies or between companies and their partners or directors.
      </p>
      <p>
        Tax regulations require proof that these transactions are carried out at market
        value in order to avoid adjustments and penalties from the tax inspection.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        How we help
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Determining the market value of the property involved.</li>
        <li>Selecting and justifying accepted valuation methods.</li>
        <li>Preparing reports and supporting documentation for inspections.</li>
      </ul>
    </ServiceModal>

    <ServiceModal id="inventario-bienes" title="Real estate asset inventories">
      <p>
        We prepare updated inventories of real estate assets for companies, family
        holdings and public bodies.
      </p>
      <p>
        An up-to-date inventory allows cost reduction, better control and compliance with
        legal obligations.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Benefits
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Reduction of insurance premiums by adjusting insured values.</li>
        <li>Optimisation of tax depreciation.</li>
        <li>Improved internal control of real estate assets.</li>
        <li>
          Compliance with legal inventory requirements for local and regional
          administrations.
        </li>
      </ul>
    </ServiceModal>

    <ServiceModal
      id="adm-local"
      title="Valuations for local authorities"
    >
      <p>
        We prepare valuations for administrative proceedings handled by municipalities and
        other public entities.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Typical files
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Supplementary tax assessments for licences and fees.</li>
        <li>Valuation of urban development rights.</li>
        <li>Penalties for unauthorised works.</li>
        <li>Administrative concessions and related fees.</li>
      </ul>
      <p>
        Our reports provide technical grounds for submissions to the Administration and
        help bring amounts in line with reasonable values.
      </p>
    </ServiceModal>

    <ServiceModal
      id="analisis-inversiones"
      title="Real estate investment analysis"
    >
      <p>
        We study the economic feasibility of property investments through a comprehensive
        technical and financial analysis.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Includes
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Valuation of the asset and its alternative exploitation scenarios.</li>
        <li>Profitability analysis and projected cash flows.</li>
        <li>Study of planning charges and legal constraints.</li>
        <li>Risk assessment and sensitivity to market changes.</li>
      </ul>
      <p>
        This analysis helps investors make decisions with greater confidence and in line
        with their asset strategy.
      </p>
    </ServiceModal>

    <!-- Final CTA -->
    <section class="section-animate py-20 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"
        ></div>
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl lg:text-4xl font-black text-white mb-6 leading-tight">
          Do you need a property valuation?
        </h2>
        <p class="text-white/90 text-lg mb-8">
          Our team can review your case and advise you on valuations for private,
          tax-related or court purposes.
        </p>
        <a
          href="/en/contact"
          class="inline-flex items-center justify-center bg-white text-primary px-10 py-4 rounded font-black text-sm tracking-[0.2em] uppercase shadow-2xl hover:bg-slate-50 transition-colors"
        >
          Contact us
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>


