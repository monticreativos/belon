---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import ServiceModal from "../../components/ServiceModal.astro";
---

<BaseLayout title="Urban planning and land management | Consultoría Belón">
  <Navbar />

  <main>
    <!-- Hero -->
    <section
      class="section-animate relative bg-white dark:bg-background-dark py-20 lg:py-24 overflow-hidden"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(0,141,210,0.2),transparent_70%)]"
      ></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-[0.2em] uppercase mb-5"
          >
            <span class="material-symbols-outlined text-sm">map</span>
            Urban planning and land management
          </div>
          <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-600 dark:text-slate-50 leading-[1.05] mb-6"
          >
            Urban planning and
            <span class="text-primary">land management</span>
          </h1>
          <p class="text-lg text-neutral-500 dark:text-slate-300 max-w-2xl space-y-3">
            Consultoría Belón provides specialist urban planning advice for landowners,
            investors and developers. Our technical team coordinates and develops planning
            projects, manages licences and analyses the legal and economic feasibility of
            land.
          </p>
          <p class="mt-4 text-sm text-neutral-500 dark:text-slate-300 max-w-2xl">
            We have extensive experience in urban planning, land development, technical
            reports and administrative procedures. Consultoría Belón works from its
            technical offices in Madrid and Marbella.
          </p>
        </div>
      </div>
    </section>

    <!-- Services grid -->
    <section class="section-animate-delayed py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-12">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Urban planning services
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Below are our main urban planning services in interactive format. Click on
            each card to see more details.
          </p>
        </header>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <ServiceCard
            id="pgou"
            icon="location_city"
            title="Marbella Master Plan 1986"
            description="Specialist advice on the 1986 General Urban Development Plan (PGOU) of Marbella."
          />
          <ServiceCard
            id="licencias-obras"
            icon="construction"
            title="Building permits"
            description="End-to-end management of major and minor works licences for building and refurbishment projects."
          />
          <ServiceCard
            id="licencias-apertura"
            icon="storefront"
            title="Business opening licences"
            description="Design and processing of opening licences for commercial premises and economic activities."
          />
          <ServiceCard
            id="desarrollos-urbanisticos"
            icon="domain_add"
            title="Urban development"
            description="Consultancy for land development, partial plans and urbanisation projects."
          />
          <ServiceCard
            id="informes-urbanisticos"
            icon="description"
            title="Planning reports"
            description="Reports clarifying the legal status and development potential of plots and buildings."
          />
          <ServiceCard
            id="disciplina-urbanistica"
            icon="gavel"
            title="Planning enforcement"
            description="Advice and defence in planning enforcement proceedings before local authorities."
          />
          <ServiceCard
            id="cargas-urbanisticas"
            icon="inventory"
            title="Planning charges analysis"
            description="Preliminary analysis of planning obligations and charges linked to land development."
          />
          <ServiceCard
            id="planeamiento-gestion"
            icon="route"
            title="Planning and land management"
            description="Advice on planning procedures and land management entities and boards."
          />
        </div>
      </div>
    </section>

    <!-- Modals -->
    <ServiceModal id="pgou" title="Marbella Master Plan 1986">
      <p>
        Consultoría Belón has extensive experience with Marbella's 1986 General Urban
        Development Plan (PGOU). Our team took part in its management from within Marbella
        City Council, which allows us to offer deep insight into the city's planning
        framework.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Services
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Urban planning queries.</li>
        <li>Planning reports on land classification and zoning.</li>
        <li>Analysis of planning rights and obligations.</li>
        <li>Feasibility studies for real estate investments.</li>
        <li>Urban planning due diligence prior to acquisitions.</li>
      </ul>
    </ServiceModal>

    <ServiceModal id="licencias-obras" title="Building permits">
      <p>
        We manage major and minor building permits, coordinating all the steps required to
        carry out your project with full legal and technical certainty.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Services
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Administrative management of permits.</li>
        <li>Preparation of technical project documentation.</li>
        <li>Monitoring of the file until final approval.</li>
        <li>Coordination with municipal technical services.</li>
      </ul>
      <p>
        Our technical team enables us to offer an integrated solution from the initial
        project to the execution phase.
      </p>
    </ServiceModal>

    <ServiceModal id="licencias-apertura" title="Business opening licences">
      <p>
        We provide full advice and management to obtain opening licences for all kinds of
        businesses and activities.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Includes
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Preparation of the technical project.</li>
        <li>Administrative processing before the City Council.</li>
        <li>Coordination with engineering departments.</li>
        <li>Technical support throughout the whole process.</li>
      </ul>
      <p>
        Our services are aimed at both private individuals and companies that need to start
        their activity quickly and safely.
      </p>
    </ServiceModal>

    <ServiceModal id="desarrollos-urbanisticos" title="Urban development">
      <p>
        Consultoría Belón acts as real estate consultant in land management and
        development, taking part in all phases of the planning process.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        We work on
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Partial plans.</li>
        <li>Urbanisation projects.</li>
        <li>Reparceling projects.</li>
        <li>
          By-laws and statutes for compensation boards and other land management entities.
        </li>
      </ul>
      <p>
        We coordinate all stakeholders in the planning process and manage relations with
        public administrations and developers.
      </p>
    </ServiceModal>

    <ServiceModal id="informes-urbanisticos" title="Planning reports">
      <p>
        We prepare planning reports that allow clients to understand the legal status of a
        property or plot before making decisions or starting investments.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        They include
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Planning certificates.</li>
        <li>Analysis of landowners' rights and obligations.</li>
        <li>Reports on planning lawfulness.</li>
        <li>Preliminary studies for the commercialisation of assets.</li>
      </ul>
      <p>
        These reports help to save time in administrative procedures and facilitate
        purchase and sale operations.
      </p>
    </ServiceModal>

    <ServiceModal id="disciplina-urbanistica" title="Planning enforcement">
      <p>
        If you have received a notice from the City Council related to planning
        enforcement, it is essential to react quickly and with specialised advice.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        We handle cases related to
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Enforcement orders.</li>
        <li>Legalisation orders.</li>
        <li>Demolition orders.</li>
        <li>Stop-work notices.</li>
        <li>Closure of activities.</li>
      </ul>
      <p>
        We analyse your case and prepare the necessary submissions to defend your rights
        before the administration.
      </p>
    </ServiceModal>

    <ServiceModal
      id="cargas-urbanisticas"
      title="Planning charges and development obligations"
    >
      <p>
        Before acquiring land it is essential to know whether there are planning charges
        that may affect its value or future development.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        We analyse
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Non-consolidated urban land.</li>
        <li>Pending planning obligations.</li>
        <li>Costs derived from land development.</li>
      </ul>
      <p>
        This analysis makes it possible to determine the economic feasibility of a real
        estate investment.
      </p>
    </ServiceModal>

    <ServiceModal
      id="planeamiento-gestion"
      title="Planning and land management services"
    >
      <p>
        We advise on territorial and urban planning processes, accompanying clients
        throughout the land transformation and management cycle.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Services
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Advice on land transformation processes.</li>
        <li>Reclassification and rezoning of land.</li>
        <li>Organisation of compensation boards.</li>
        <li>Management of land conservation entities.</li>
      </ul>
      <p>
        Our team combines technical and legal knowledge to coordinate complex planning and
        development projects.
      </p>
    </ServiceModal>

    <!-- Final CTA -->
    <section class="section-animate py-20 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"
        ></div>
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl lg:text-4xl font-black text-white mb-6 leading-tight">
          Do you need urban planning advice?
        </h2>
        <p class="text-white/90 text-lg mb-8">
          Our technical team can review your case and advise you on any planning
          procedure, from licences to full-scale land development.
        </p>
        <a
          href="/en/contact"
          class="inline-flex items-center justify-center bg-white text-primary px-10 py-4 rounded font-black text-sm tracking-[0.2em] uppercase shadow-2xl hover:bg-slate-50 transition-colors"
        >
          Contact us
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

