---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import HomeHero from "../../components/HomeHero.astro";
import UrbanismoHighlight from "../../components/UrbanismoHighlight.astro";
import Services from "../../components/Services.astro";
import ServicesOverview from "../../components/ServicesOverview.astro";
import AboutStudio from "../../components/AboutStudio.astro";
import CTA from "../../components/CTA.astro";
import Footer from "../../components/Footer.astro";
import { pageMeta } from "../../config/seo";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base.slice(0, -1) : base;
const meta = pageMeta["/"];
---

<BaseLayout title={meta.titleEn} description={meta.descriptionEn}>
  <Navbar />
  <HomeHero locale="en" basePath={basePath} />
  <UrbanismoHighlight />
  <Services />
  <ServicesOverview />
  <AboutStudio />
  <CTA />
  <Footer />
</BaseLayout>

