---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ServiceModal from "../components/ServiceModal.astro";
---

<BaseLayout title="Urbanismo y gestión del suelo | Consultoría Belón">
  <Navbar />

  <main>
    <!-- Hero -->
    <section
      class="section-animate relative bg-white dark:bg-background-dark py-20 lg:py-24 overflow-hidden"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(0,141,210,0.2),transparent_70%)]"
      ></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-[0.2em] uppercase mb-5"
          >
            <span class="material-symbols-outlined text-sm">map</span>
            Urbanismo y gestión del suelo
          </div>
          <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-600 dark:text-slate-50 leading-[1.05] mb-6"
          >
            Urbanismo y
            <span class="text-primary">gestión del suelo</span>
          </h1>
          <p class="text-lg text-neutral-500 dark:text-slate-300 max-w-2xl space-y-3">
            Consultoría Belón ofrece asesoramiento urbanístico especializado para
            propietarios, inversores y promotores. Nuestro equipo técnico coordina y
            desarrolla proyectos urbanísticos, gestiona licencias y analiza la
            viabilidad legal y económica del suelo.
          </p>
          <p class="mt-4 text-sm text-neutral-500 dark:text-slate-300 max-w-2xl">
            Tenemos experiencia en planeamiento urbanístico, gestión de suelo,
            informes urbanísticos y tramitación ante la administración. Consultoría
            Belón dispone de departamento técnico en Madrid y Marbella.
          </p>
        </div>
      </div>
    </section>

    <!-- Services grid -->
    <section class="section-animate-delayed py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-12">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Servicios de urbanismo
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Presentamos nuestros principales servicios urbanísticos en formato
            interactivo. Haga clic en cada tarjeta para ver el detalle del servicio.
          </p>
        </header>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <ServiceCard
            id="pgou"
            icon="location_city"
            title="PGOU Marbella 1986"
            description="Consultoría especializada en el planeamiento urbanístico de Marbella y su PGOU de 1986."
          />
          <ServiceCard
            id="licencias-obras"
            icon="construction"
            title="Licencias de obras"
            description="Gestión integral de licencias de obra mayor y menor para proyectos de obra y reforma."
          />
          <ServiceCard
            id="licencias-apertura"
            icon="storefront"
            title="Licencias de apertura"
            description="Proyecto y tramitación de licencias de apertura para negocios y actividades económicas."
          />
          <ServiceCard
            id="desarrollos-urbanisticos"
            icon="domain_add"
            title="Desarrollos urbanísticos"
            description="Consultoría en desarrollo de suelo, planes parciales y proyectos de urbanización."
          />
          <ServiceCard
            id="informes-urbanisticos"
            icon="description"
            title="Informes urbanísticos"
            description="Informes que aclaran la situación legal y el potencial urbanístico de inmuebles y terrenos."
          />
          <ServiceCard
            id="disciplina-urbanistica"
            icon="gavel"
            title="Disciplina urbanística"
            description="Asesoramiento y defensa en expedientes de disciplina urbanística ante el Ayuntamiento."
          />
          <ServiceCard
            id="cargas-urbanisticas"
            icon="inventory"
            title="Estudio de cargas"
            description="Análisis previo de cargas urbanísticas y obligaciones asociadas al desarrollo del suelo."
          />
          <ServiceCard
            id="planeamiento-gestion"
            icon="route"
            title="Planeamiento y gestión"
            description="Asesoramiento en planeamiento y procesos de gestión del suelo, juntas y entidades de conservación."
          />
        </div>
      </div>
    </section>

    <!-- Modals -->
    <ServiceModal id="pgou" title="PGOU Marbella 1986">
      <p>
        Consultoría Belón cuenta con una amplia experiencia en el PGOU de Marbella
        de 1986. Nuestro equipo participó en su gestión desde el propio Ayuntamiento
        de Marbella, lo que nos permite ofrecer un conocimiento profundo del
        planeamiento urbanístico de la ciudad.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Servicios
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Consultas urbanísticas.</li>
        <li>Informes urbanísticos sobre clasificación y calificación del suelo.</li>
        <li>Análisis de derechos y obligaciones urbanísticas.</li>
        <li>Estudio de viabilidad de inversiones inmobiliarias.</li>
        <li>Due diligence urbanística previa a operaciones de compra o venta.</li>
      </ul>
    </ServiceModal>

    <ServiceModal id="licencias-obras" title="Licencias de obras">
      <p>
        Gestionamos licencias de obra mayor y menor, coordinando todos los trámites
        necesarios para llevar a cabo su proyecto con seguridad jurídica y técnica.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Servicios
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Gestión administrativa de licencias.</li>
        <li>Elaboración de proyectos técnicos.</li>
        <li>Seguimiento del expediente hasta su resolución.</li>
        <li>Coordinación con la administración y servicios técnicos municipales.</li>
      </ul>
      <p>
        Nuestro equipo técnico permite ofrecer una solución integral desde el
        proyecto hasta la ejecución de la obra.
      </p>
    </ServiceModal>

    <ServiceModal id="licencias-apertura" title="Licencias de apertura">
      <p>
        Ofrecemos asesoramiento y gestión completa para la obtención de licencias de
        apertura para negocios y actividades.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Incluye
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Elaboración del proyecto técnico.</li>
        <li>Tramitación administrativa ante el Ayuntamiento.</li>
        <li>Coordinación con el departamento de ingeniería.</li>
        <li>Asesoramiento técnico durante todo el proceso.</li>
      </ul>
      <p>
        Nuestros servicios están dirigidos tanto a particulares como a empresas que
        necesitan iniciar su actividad de manera rápida y segura.
      </p>
    </ServiceModal>

    <ServiceModal id="desarrollos-urbanisticos" title="Desarrollos urbanísticos">
      <p>
        Consultoría Belón actúa como consultor inmobiliario en la gestión y
        desarrollo del suelo, participando en todas las fases del proceso
        urbanístico.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Participamos en
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Planes parciales.</li>
        <li>Proyectos de urbanización.</li>
        <li>Proyectos de reparcelación.</li>
        <li>Proyectos de bases y estatutos para juntas de compensación.</li>
      </ul>
      <p>
        Coordinamos todos los actores del proceso urbanístico y gestionamos la
        relación con administraciones públicas y promotores.
      </p>
    </ServiceModal>

    <ServiceModal id="informes-urbanisticos" title="Informes urbanísticos">
      <p>
        Realizamos informes urbanísticos que permiten conocer la situación legal de
        un inmueble o terreno antes de tomar decisiones o iniciar inversiones.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Incluyen
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Cédulas urbanísticas.</li>
        <li>Análisis de derechos y obligaciones del propietario.</li>
        <li>Informes de legalidad urbanística.</li>
        <li>Estudios previos para comercialización de activos inmobiliarios.</li>
      </ul>
      <p>
        Estos informes permiten ahorrar tiempo en trámites administrativos y
        facilitar operaciones de compraventa.
      </p>
    </ServiceModal>

    <ServiceModal id="disciplina-urbanistica" title="Disciplina urbanística">
      <p>
        Si ha recibido una notificación del Ayuntamiento relacionada con disciplina
        urbanística es importante actuar con rapidez.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Gestionamos expedientes relacionados con
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Órdenes de ejecución.</li>
        <li>Órdenes de legalización.</li>
        <li>Órdenes de demolición.</li>
        <li>Paralización de obras.</li>
        <li>Clausura de actividades.</li>
      </ul>
      <p>
        Analizamos su caso y preparamos las alegaciones necesarias para defender sus
        derechos ante la administración.
      </p>
    </ServiceModal>

    <ServiceModal id="cargas-urbanisticas" title="Estudio de cargas urbanísticas">
      <p>
        Antes de adquirir una propiedad es fundamental conocer si existen cargas
        urbanísticas que puedan afectar a su valor o a su desarrollo futuro.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Analizamos
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Suelo urbano no consolidado.</li>
        <li>Obligaciones urbanísticas pendientes.</li>
        <li>Costes derivados del desarrollo del suelo.</li>
      </ul>
      <p>
        Este análisis permite determinar la viabilidad económica de una inversión
        inmobiliaria.
      </p>
    </ServiceModal>

    <ServiceModal id="planeamiento-gestion" title="Planeamiento y gestión del suelo">
      <p>
        Asesoramos en procesos de planificación territorial y urbanística,
        acompañando al cliente en la transformación y gestión del suelo.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Servicios
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Asesoramiento en transformaciones de suelo.</li>
        <li>Recalificación de terrenos.</li>
        <li>Organización de juntas de compensación.</li>
        <li>Gestión de entidades urbanísticas de conservación.</li>
      </ul>
      <p>
        Nuestro equipo combina conocimiento técnico y jurídico para coordinar
        proyectos urbanísticos complejos.
      </p>
    </ServiceModal>

    <!-- CTA final -->
    <section class="section-animate py-20 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"
        ></div>
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl lg:text-4xl font-black text-white mb-6 leading-tight">
          ¿Necesita asesoramiento urbanístico?
        </h2>
        <p class="text-white/90 text-lg mb-8">
          Nuestro equipo técnico puede estudiar su caso y asesorarle en cualquier
          trámite urbanístico, desde licencias hasta desarrollos completos de suelo.
        </p>
        <a
          href="/contacto"
          class="inline-flex items-center justify-center bg-white text-primary px-10 py-4 rounded font-black text-sm tracking-[0.2em] uppercase shadow-2xl hover:bg-slate-50 transition-colors"
        >
          Contactar con nosotros
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Script muy sencillo para abrir/cerrar modales -->
  <script is:inline>
    if (typeof window !== "undefined") {
      document.addEventListener("DOMContentLoaded", function () {
        var openButtons = document.querySelectorAll("[data-open-modal]");
        var overlays = document.querySelectorAll("[data-modal-overlay]");

        function openModal(id) {
          var overlay = document.getElementById("modal-" + id);
          if (!overlay) return;
          overlay.classList.remove("hidden");
          overlay.classList.add("flex");
        }

        function closeModal(id) {
          var overlay = document.getElementById("modal-" + id);
          if (!overlay) return;
          overlay.classList.add("hidden");
          overlay.classList.remove("flex");
        }

        openButtons.forEach(function (btn) {
          btn.addEventListener("click", function () {
            var id = btn.getAttribute("data-open-modal");
            if (id) openModal(id);
          });
        });

        overlays.forEach(function (overlay) {
          overlay.addEventListener("click", function (event) {
            if (event.target === overlay) {
              var id = overlay.id.replace("modal-", "");
              closeModal(id);
            }
          });

          var closeBtn = overlay.querySelector("[data-close-modal]");
          if (closeBtn) {
            closeBtn.addEventListener("click", function () {
              var id = closeBtn.getAttribute("data-close-modal");
              if (id) closeModal(id);
            });
          }
        });
      });
    }
  </script>
</BaseLayout>
