---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { pageMeta } from "../config/seo";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base.slice(0, -1) : base;
const meta = pageMeta["/contacto"];
---

<BaseLayout title={meta.title} description={meta.description}>
  <Navbar />

  <main>
    <!-- HERO -->
    <section
      class="section-animate relative bg-white dark:bg-background-dark py-16 lg:py-20 border-b border-slate-100 dark:border-slate-800 overflow-hidden"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(0,141,210,0.16),transparent_70%)]"
      ></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <header class="max-w-3xl">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-[0.2em] uppercase mb-5"
          >
            <span class="material-symbols-outlined text-sm">support_agent</span>
            Contacto
          </div>
          <h1
            class="text-4xl sm:text-5xl font-black text-neutral-600 dark:text-slate-50 mb-4"
          >
            Contacto
          </h1>
          <p class="text-lg text-neutral-500 dark:text-slate-300 max-w-2xl">
            Si necesita asesoramiento en urbanismo, valoraciones inmobiliarias,
            gestión patrimonial o recursos administrativos, nuestro equipo estará
            encantado de estudiar su caso.
          </p>
        </header>
      </div>
    </section>

    <!-- FORM + CONTACT INFO -->
    <section class="section-animate-delayed py-16 lg:py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)] gap-12 items-start">
          <!-- Form -->
          <section
            aria-labelledby="contact-form-title"
            class="rounded-2xl bg-white dark:bg-slate-900 shadow-sm shadow-slate-200/80 dark:shadow-slate-900/60 border border-slate-200/80 dark:border-slate-700 p-6 sm:p-8"
          >
            <h2
              id="contact-form-title"
              class="text-xl sm:text-2xl font-bold text-neutral-700 dark:text-slate-50 mb-2"
            >
              Envíenos su consulta
            </h2>
            <p class="text-sm text-neutral-500 dark:text-slate-300 mb-6">
              Complete el formulario y le responderemos con la mayor brevedad posible.
            </p>

            <form class="space-y-5" method="post">
              <div class="space-y-1.5">
                <label
                  for="nombre"
                  class="block text-sm font-semibold text-neutral-600 dark:text-slate-100"
                  >Nombre completo</label
                >
                <input
                  id="nombre"
                  name="nombre"
                  type="text"
                  required
                  autocomplete="name"
                  class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                  placeholder="Nombre y apellidos"
                />
              </div>

              <div class="grid sm:grid-cols-2 gap-4">
                <div class="space-y-1.5">
                  <label
                    for="email"
                    class="block text-sm font-semibold text-neutral-600 dark:text-slate-100"
                    >Email</label
                  >
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                    placeholder="su@email.com"
                  />
                </div>
                <div class="space-y-1.5">
                  <label
                    for="telefono"
                    class="block text-sm font-semibold text-neutral-600 dark:text-slate-100"
                    >Teléfono</label
                  >
                  <input
                    id="telefono"
                    name="telefono"
                    type="tel"
                    autocomplete="tel"
                    pattern="[\d\s+()-]{6,}"
                    class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                    placeholder="+34 ..."
                  />
                </div>
              </div>

              <div class="space-y-1.5">
                <label
                  for="tipo"
                  class="block text-sm font-semibold text-neutral-600 dark:text-slate-100"
                  >Tipo de consulta</label
                >
                <select
                  id="tipo"
                  name="tipo"
                  required
                  class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                >
                  <option value="">Seleccione una opción</option>
                  <option value="urbanismo">Urbanismo</option>
                  <option value="valoraciones">Valoraciones inmobiliarias</option>
                  <option value="patrimonio">Gestión patrimonial</option>
                  <option value="recursos">Recursos administrativos</option>
                  <option value="otro">Otro</option>
                </select>
              </div>

              <div class="space-y-1.5">
                <label
                  for="mensaje"
                  class="block text-sm font-semibold text-neutral-600 dark:text-slate-100"
                  >Mensaje</label
                >
                <textarea
                  id="mensaje"
                  name="mensaje"
                  rows="5"
                  required
                  class="block w-full rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 px-4 py-3 text-sm text-neutral-700 dark:text-slate-100 shadow-inner focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary resize-none"
                  placeholder="Describa brevemente su consulta..."
                ></textarea>
              </div>

              <div class="space-y-3 pt-1">
                <div class="flex items-start gap-2">
                  <input
                    id="acepto-datos-contacto"
                    name="acepto_datos"
                    type="checkbox"
                    required
                    class="mt-0.5 size-4 rounded border-slate-300 text-primary focus:ring-primary"
                  />
                  <label
                    for="acepto-datos-contacto"
                    class="text-xs text-neutral-500 dark:text-slate-300"
                  >
                    He leído y acepto la
                    <a
                      href={`${basePath}/politica-privacidad`}
                      class="underline underline-offset-2 decoration-primary/70 hover:text-primary"
                      >política de privacidad</a
                    >
                    y el tratamiento de mis datos para gestionar mi consulta.
                  </label>
                </div>
                <div class="flex items-start gap-2">
                  <input
                    id="newsletter-contacto"
                    name="newsletter"
                    type="checkbox"
                    class="mt-0.5 size-4 rounded border-slate-300 text-primary focus:ring-primary"
                  />
                  <label
                    for="newsletter-contacto"
                    class="text-xs text-neutral-500 dark:text-slate-300"
                  >
                    Acepto recibir información relevante y actualizaciones sobre servicios
                    de Consultoría Belón. Podrá darse de baja en cualquier momento.
                  </label>
                </div>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 pt-3">
                <p class="text-[11px] text-neutral-400 dark:text-slate-500">
                  Sus datos no se cederán a terceros salvo obligación legal. Consulte la
                  política de privacidad para más detalle.
                </p>
                <button
                  type="submit"
                  class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-3 text-xs font-black tracking-[0.25em] uppercase text-white shadow-md shadow-primary/40 hover:bg-primary/90 hover:-translate-y-0.5 transition-all"
                >
                  Enviar consulta
                </button>
              </div>
            </form>
          </section>

          <!-- Contact info -->
          <aside
            class="rounded-2xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 sm:p-7 shadow-sm shadow-slate-200/80 dark:shadow-slate-900/60 space-y-6"
          >
            <div>
              <h2 class="text-sm font-bold uppercase tracking-[0.25em] text-neutral-500 mb-3">
                Datos de contacto
              </h2>
              <div class="space-y-3 text-sm text-neutral-600 dark:text-slate-200">
                <div class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-primary text-base mt-0.5"
                    >call</span
                  >
                  <div>
                    <p class="font-semibold">Teléfono</p>
                    <p>+34 952 77 42 49</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-primary text-base mt-0.5"
                    >alternate_email</span
                  >
                  <div>
                    <p class="font-semibold">Email</p>
                    <p>info@belon.es</p>
                  </div>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-sm font-bold uppercase tracking-[0.25em] text-neutral-500 mb-3">
                Horario
              </h3>
              <p class="text-sm text-neutral-600 dark:text-slate-200">
                Lunes – Viernes<br />
                09:00 – 18:00
              </p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- OFFICES -->
    <section class="section-animate py-16 lg:py-20 bg-white dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-10">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Oficinas
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Coordinamos los proyectos desde nuestros equipos en Madrid y Marbella.
          </p>
        </header>

        <div class="grid gap-6 md:grid-cols-2">
          <article
            class="rounded-2xl border border-slate-200/80 dark:border-slate-700 bg-background-light dark:bg-slate-900/80 p-6 sm:p-7 shadow-sm shadow-slate-200/80 dark:shadow-slate-900/60"
          >
            <div class="flex items-center gap-3 mb-4">
              <span
                class="inline-flex items-center justify-center size-10 rounded-full bg-primary/10 text-primary"
              >
                <span class="material-symbols-outlined text-xl">location_city</span>
              </span>
              <div>
                <h3 class="text-base font-bold text-neutral-700 dark:text-slate-50">
                  Madrid
                </h3>
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-neutral-500">
                  Departamento técnico
                </p>
              </div>
            </div>
            <p class="text-sm text-neutral-600 dark:text-slate-300">
              Coordinación de informes urbanísticos, valoraciones y proyectos
              técnicos a nivel nacional.
            </p>
          </article>

          <article
            class="rounded-2xl border border-slate-200/80 dark:border-slate-700 bg-background-light dark:bg-slate-900/80 p-6 sm:p-7 shadow-sm shadow-slate-200/80 dark:shadow-slate-900/60"
          >
            <div class="flex items-center gap-3 mb-4">
              <span
                class="inline-flex items-center justify-center size-10 rounded-full bg-primary/10 text-primary"
              >
                <span class="material-symbols-outlined text-xl">villa</span>
              </span>
              <div>
                <h3 class="text-base font-bold text-neutral-700 dark:text-slate-50">
                  Marbella
                </h3>
                <p class="text-xs font-semibold uppercase tracking-[0.25em] text-neutral-500">
                  Consultoría Belón · Urbanismo y gestión inmobiliaria
                </p>
              </div>
            </div>
            <p class="text-sm text-neutral-600 dark:text-slate-300">
              Atención directa a clientes de la Costa del Sol y coordinación con las
              administraciones locales.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- MAP -->
    <section class="section-animate-delayed pb-16 lg:pb-20 bg-white dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="rounded-2xl overflow-hidden border border-slate-200/80 dark:border-slate-700 shadow-sm shadow-slate-200/80 dark:shadow-slate-900/60"
        >
          <div class="aspect-[16/9]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3339.417973093114!2d-4.893889!3d36.510071!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd73bf7d7bf3c8e5%3A0x5c9e4f0a2b0a7f3d!2sMarbella!5e0!3m2!1ses!2ses!4v1700000000000!5m2!1ses!2ses"
              width="600"
              height="450"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full border-0"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="section-animate py-16 lg:py-20 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"
        ></div>
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl lg:text-4xl font-black text-white mb-6 leading-tight">
          ¿Prefiere hablar directamente con nosotros?
        </h2>
        <p class="text-white/90 text-lg mb-8">
          Puede llamarnos o enviarnos su consulta a través del formulario y nuestro
          equipo se pondrá en contacto con usted lo antes posible.
        </p>
        <a
          href="tel:+34952774249"
          class="inline-flex items-center justify-center bg-white text-primary px-10 py-4 rounded-full font-black text-sm tracking-[0.25em] uppercase shadow-2xl hover:bg-slate-50 transition-colors"
        >
          Llamar ahora
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

