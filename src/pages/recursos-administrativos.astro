---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ServiceModal from "../components/ServiceModal.astro";
import { pageMeta } from "../config/seo";

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base.slice(0, -1) : base;
const meta = pageMeta["/recursos-administrativos"];
---

<BaseLayout title={meta.title} description={meta.description}>
  <Navbar />

  <main>
    <!-- Hero -->
    <section
      class="section-animate relative bg-white dark:bg-background-dark py-20 lg:py-24 overflow-hidden"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(0,141,210,0.2),transparent_70%)]"
      ></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-3xl">
          <div
            class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-[0.2em] uppercase mb-5"
          >
            <span class="material-symbols-outlined text-sm">gavel</span>
            Recursos administrativos
          </div>
          <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-600 dark:text-slate-50 leading-[1.05] mb-6"
          >
            Recursos administrativos y
            <span class="text-primary">defensa frente a la Administración</span>
          </h1>
          <p class="text-lg text-neutral-500 dark:text-slate-300 max-w-2xl mb-3">
            El derecho administrativo regula las relaciones entre las administraciones
            públicas y los ciudadanos.
          </p>
          <p class="text-sm text-neutral-500 dark:text-slate-300 max-w-2xl mb-3">
            En los últimos años estas relaciones se han vuelto cada vez más
            complejas, generando conflictos relacionados con licencias, sanciones,
            responsabilidad patrimonial o procedimientos administrativos.
          </p>
          <p class="text-sm text-neutral-500 dark:text-slate-300 max-w-2xl">
            Consultoría Belón cuenta con amplia experiencia en esta materia y asesora
            a particulares y empresas en la defensa de sus derechos frente a la
            administración.
          </p>
        </div>
      </div>
    </section>

    <!-- Services grid -->
    <section class="section-animate-delayed py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-12">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Servicios en recursos administrativos
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Presentamos nuestras principales líneas de trabajo en materia de recursos
            y reclamaciones frente a la Administración.
          </p>
        </header>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <ServiceCard
            id="recursos-administrativos"
            icon="description"
            title="Recursos administrativos"
            description="Asesoramiento y representación en recursos frente a resoluciones administrativas."
          />
          <ServiceCard
            id="reclamaciones-administracion"
            icon="campaign"
            title="Reclamaciones frente a la administración"
            description="Reclamaciones económicas y de responsabilidad patrimonial contra administraciones públicas."
          />
          <ServiceCard
            id="multas-sanciones"
            icon="report"
            title="Multas y sanciones"
            description="Defensa en procedimientos sancionadores y recursos contra multas administrativas."
          />
          <ServiceCard
            id="informes-periciales"
            icon="analytics"
            title="Informes periciales"
            description="Informes técnicos de apoyo en procedimientos judiciales y administrativos."
          />
        </div>
      </div>
    </section>

    <!-- Modals -->
    <ServiceModal
      id="recursos-administrativos"
      title="Recursos administrativos"
    >
      <p>
        Ofrecemos asesoramiento y representación en recursos administrativos tanto en
        vía administrativa como judicial.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Nuestros servicios incluyen
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Recursos administrativos de cualquier tipo.</li>
        <li>Recursos en vía previa administrativa.</li>
        <li>Recursos contencioso-administrativos.</li>
        <li>Defensa frente a resoluciones administrativas.</li>
      </ul>
      <p>
        Analizamos cada caso para determinar la mejor estrategia legal frente a la
        administración pública.
      </p>
    </ServiceModal>

    <ServiceModal
      id="reclamaciones-administracion"
      title="Reclamaciones frente a la administración"
    >
      <p>
        Gestionamos reclamaciones contra administraciones públicas cuando se han
        producido daños o perjuicios derivados de su actuación o inactividad.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Actuaciones habituales
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Responsabilidad patrimonial de la administración.</li>
        <li>Reclamación de intereses de demora por retrasos en pagos.</li>
        <li>Reclamaciones económicas frente a administraciones públicas.</li>
      </ul>
      <p>
        Nuestro objetivo es garantizar que los ciudadanos reciban la compensación que
        les corresponde cuando la Administración ocasiona un perjuicio.
      </p>
    </ServiceModal>

    <ServiceModal
      id="multas-sanciones"
      title="Multas y sanciones administrativas"
    >
      <p>
        Asesoramos en procedimientos sancionadores de carácter administrativo,
        analizando la legalidad del procedimiento y las pruebas aportadas.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Casos más habituales
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>Sanciones urbanísticas.</li>
        <li>Sanciones tributarias.</li>
        <li>Expedientes administrativos sancionadores.</li>
        <li>Recursos contra multas.</li>
      </ul>
      <p>
        Estudiamos cada expediente para detectar posibles irregularidades en el
        procedimiento administrativo y plantear la mejor defensa.
      </p>
    </ServiceModal>

    <ServiceModal
      id="informes-periciales"
      title="Informes periciales para procedimientos judiciales"
    >
      <p>
        El informe pericial es un documento técnico elaborado por expertos en el que
        se exponen conclusiones basadas en conocimientos especializados.
      </p>
      <p>
        Estos informes pueden ser solicitados por el juez o por cualquiera de las
        partes en un procedimiento judicial, y tienen como finalidad aportar claridad
        técnica en asuntos complejos.
      </p>
      <p class="font-semibold text-xs tracking-[0.25em] uppercase text-primary">
        Cómo trabajamos
      </p>
      <ul class="list-disc pl-5 space-y-1.5">
        <li>
          Análisis detallado de la documentación y de la situación objeto de
          peritaje.
        </li>
        <li>Emisión de conclusiones claras, objetivas y fundamentadas.</li>
        <li>Defensa del informe en sede judicial cuando es necesario.</li>
      </ul>
    </ServiceModal>

    <!-- CTA final -->
    <section class="section-animate py-20 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"
        ></div>
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl lg:text-4xl font-black text-white mb-6 leading-tight">
          ¿Tiene un problema con la Administración?
        </h2>
        <p class="text-white/90 text-lg mb-8">
          Nuestro equipo puede estudiar su caso y asesorarle en la defensa de sus
          derechos frente a la administración pública.
        </p>
        <a
          href={`${basePath}/contacto`}
          class="inline-flex items-center justify-center bg-white text-primary px-10 py-4 rounded font-black text-sm tracking-[0.2em] uppercase shadow-2xl hover:bg-slate-50 transition-colors"
        >
          Contactar con nosotros
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <!-- Minimal modal script -->
  <script is:inline>
    (() => {
      if (typeof window === "undefined") return;

      const openButtons = document.querySelectorAll("[data-open-modal]");
      const overlays = document.querySelectorAll("[data-modal-overlay]");

      const openModal = (id) => {
        const overlay = document.getElementById(`modal-${id}`);
        if (!overlay) return;
        overlay.classList.remove("hidden");
        overlay.classList.add("flex");
      };

      const closeModal = (id) => {
        const overlay = document.getElementById(`modal-${id}`);
        if (!overlay) return;
        overlay.classList.add("hidden");
        overlay.classList.remove("flex");
      };

      openButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.getAttribute("data-open-modal");
          if (id) openModal(id);
        });
      });

      overlays.forEach((overlay) => {
        overlay.addEventListener("click", (event) => {
          if (event.target === overlay) {
            const id = overlay.id.replace("modal-", "");
            closeModal(id);
          }
        });

        const closeBtn = overlay.querySelector("[data-close-modal]");
        if (closeBtn) {
          closeBtn.addEventListener("click", () => {
            const id = closeBtn.getAttribute("data-close-modal");
            if (id) closeModal(id);
          });
        }
      });
    })();
  </script>
</BaseLayout>

