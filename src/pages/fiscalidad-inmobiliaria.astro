---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Fiscalidad inmobiliaria | Consultoría Belón">
  <Navbar />

  <main>
    <!-- Hero -->
    <section
      class="section-animate relative bg-white dark:bg-background-dark py-20 lg:py-24 overflow-hidden"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(0,141,210,0.18),transparent_70%)]"
      ></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)] gap-16 items-center">
          <header>
            <div
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-[0.2em] uppercase mb-5"
            >
              <span class="material-symbols-outlined text-sm">account_balance</span>
              Área fiscal inmobiliaria
            </div>
            <h1
              class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-600 dark:text-slate-50 leading-[1.05] mb-6"
            >
              Fiscalidad
              <span class="text-primary">inmobiliaria</span>
            </h1>
            <p class="text-lg text-neutral-500 dark:text-slate-300 max-w-xl">
              Asesoramos en la tributación vinculada a la propiedad, adquisición y
              transmisión de inmuebles, planificando cada operación para optimizar la
              carga fiscal y minimizar riesgos frente a la Administración.
            </p>
          </header>
          <aside
            class="rounded-2xl border border-primary/20 dark:border-primary/40 bg-white/90 dark:bg-slate-900/80 p-6 space-y-4 shadow-[0_18px_45px_rgba(15,23,42,0.12)] backdrop-blur-sm"
          >
            <div class="inline-flex items-center gap-2 text-primary mb-1">
              <span class="material-symbols-outlined text-base">fact_check</span>
              <p class="text-xs font-bold uppercase tracking-[0.25em]">
                Qué obtiene el cliente
              </p>
            </div>
            <ul class="space-y-2 text-sm text-neutral-500 dark:text-slate-200">
              <li>• Mapa claro de los impuestos que afectan a cada operación.</li>
              <li>
                • Escenarios comparados según la forma de adquisición
                (compraventa, herencia, donación, aportaciones, etc.).
              </li>
              <li>• Documentación técnica para justificar el valor declarado.</li>
              <li>• Acompañamiento en la relación con notaría, Catastro y Hacienda.</li>
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <!-- Fiscalidad inmobiliaria -->
    <section class="section-animate-delayed py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-10">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Fiscalidad inmobiliaria
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Ayudamos a comprender y planificar los impuestos que afectan a los
            inmuebles, tanto en operaciones puntuales como en la gestión continua
            de un patrimonio inmobiliario.
          </p>
        </header>

        <div class="grid md:grid-cols-3 gap-6">
          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">receipt_long</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Principales impuestos
            </h3>
            <ul class="space-y-1.5 text-sm text-neutral-500 dark:text-slate-300">
              <li>• Impuesto de Sucesiones y Donaciones.</li>
              <li>• IVA inmobiliario.</li>
              <li>• Impuesto de Transmisiones Patrimoniales (ITP).</li>
              <li>• Actos Jurídicos Documentados (AJD).</li>
              <li>• IRPF por ganancias patrimoniales.</li>
              <li>• Plusvalía municipal.</li>
            </ul>
          </article>

          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">sync_alt</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Tipo de operación
            </h3>
            <p class="text-sm text-neutral-500 dark:text-slate-300 mb-3">
              La fiscalidad cambia de forma significativa según cómo se adquiere o
              transmite el inmueble:
            </p>
            <ul class="space-y-1.5 text-sm text-neutral-500 dark:text-slate-300">
              <li>• Compraventa entre particulares o con promotor.</li>
              <li>• Herencias y adjudicaciones de herencia.</li>
              <li>• Donaciones entre familiares.</li>
              <li>• Aportaciones a sociedades y permutas.</li>
            </ul>
          </article>

          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">task</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Planificación y documentación
            </h3>
            <p class="text-sm text-neutral-500 dark:text-slate-300 mb-3">
              Diseñamos la operación para que el impacto fiscal sea previsible y
              defendible.
            </p>
            <ul class="space-y-1.5 text-sm text-neutral-500 dark:text-slate-300">
              <li>• Cuadros comparativos de escenarios fiscales.</li>
              <li>• Revisión de borradores de escrituras y cláusulas fiscales.</li>
              <li>• Coordinación de informes técnicos y tasaciones de apoyo.</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- Catastro -->
    <section class="section-animate py-20 bg-white dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-10">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Catastro
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Revisamos la información catastral de los inmuebles y detectamos
            discrepancias que puedan afectar a la carga fiscal del propietario.
          </p>
        </header>

        <div class="grid md:grid-cols-3 gap-6">
          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-background-light/80 dark:bg-slate-900/70"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">landscape</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Papel del valor catastral
            </h3>
            <p class="text-sm text-neutral-500 dark:text-slate-300">
              Referencia clave para impuestos como el IBI, la plusvalía municipal y
              determinados recargos autonómicos. Un valor inadecuado implica pagar
              de más cada año.
            </p>
          </article>

          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-background-light/80 dark:bg-slate-900/70"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">search</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Análisis técnico
            </h3>
            <p class="text-sm text-neutral-500 dark:text-slate-300">
              Contrastamos la ficha catastral con la realidad física, urbanística y
              documental del inmueble para comprobar si el valor asignado es
              coherente.
            </p>
          </article>

          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-background-light/80 dark:bg-slate-900/70"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">gavel</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Tramitaciones habituales
            </h3>
            <ul class="space-y-1.5 text-sm text-neutral-500 dark:text-slate-300">
              <li>• Alegaciones frente a notificaciones y regularizaciones catastrales.</li>
              <li>• Recursos administrativos ante Catastro y Ayuntamiento.</li>
              <li>• Solicitud de revisión de valores catastrales desajustados.</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- Liquidaciones complementarias -->
    <section class="section-animate-delayed py-20 bg-background-light dark:bg-background-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <header class="max-w-3xl mb-10">
          <div class="h-1 w-16 bg-primary/70 mb-4 rounded-full"></div>
          <h2 class="text-3xl font-black mb-3 uppercase tracking-tight">
            Liquidaciones complementarias
          </h2>
          <p class="text-neutral-500 dark:text-slate-300">
            Tras la compra de un inmueble, la Administración puede revisar el valor
            declarado y girar una liquidación complementaria si considera que el
            precio es inferior al valor de referencia.
          </p>
        </header>

        <div class="grid md:grid-cols-3 gap-6">
          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">info</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Qué es y por qué llega
            </h3>
            <p class="text-sm text-neutral-500 dark:text-slate-300">
              Comparamos la liquidación con el valor de referencia y la realidad del
              inmueble para determinar si la actuación de la Administración está
              justificada.
            </p>
          </article>

          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">grading</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Revisión de la valoración
            </h3>
            <ul class="space-y-1.5 text-sm text-neutral-500 dark:text-slate-300">
              <li>• Análisis de métodos y coeficientes utilizados.</li>
              <li>• Contraste con datos de mercado y situación urbanística.</li>
              <li>• Comprobación de plazos y motivación del acto.</li>
            </ul>
          </article>

          <article
            class="p-7 rounded-xl border border-slate-200/80 dark:border-slate-700 bg-white dark:bg-slate-900"
          >
            <span
              class="inline-flex items-center justify-center mb-4 size-9 rounded-full bg-primary/10 text-primary"
            >
              <span class="material-symbols-outlined text-base">shield</span>
            </span>
            <h3 class="text-sm font-bold uppercase tracking-[0.2em] mb-3">
              Defensa del contribuyente
            </h3>
            <ul class="space-y-1.5 text-sm text-neutral-500 dark:text-slate-300">
              <li>• Elaboración de alegaciones y escritos de reposición.</li>
              <li>• Reclamaciones económico-administrativas fundamentadas.</li>
              <li>• Informes técnicos y comparables para sostener el valor declarado.</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- CTA específica -->
    <section class="section-animate py-20 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"
        ></div>
      </div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
        <h2 class="text-3xl lg:text-4xl font-black text-white mb-6 leading-tight">
          ¿Necesita asesoramiento fiscal inmobiliario?
        </h2>
        <p class="text-white/90 text-lg mb-8">
          Revisamos su caso y le proponemos una estrategia fiscal clara antes de
          tomar decisiones o responder a la Administración.
        </p>
        <a
          href="/contacto"
          class="inline-flex items-center justify-center bg-white text-primary px-10 py-4 rounded font-black text-sm tracking-[0.2em] uppercase shadow-2xl hover:bg-slate-50 transition-colors"
        >
          Contactar ahora
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

