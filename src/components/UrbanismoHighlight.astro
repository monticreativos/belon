---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base.slice(0, -1) : base;
---

<section class="section-animate-delayed py-20 bg-background-light dark:bg-background-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] gap-12 items-center">
      <div>
        <h2 class="text-3xl sm:text-4xl font-black mb-4 uppercase tracking-tight">
          Urbanismo
        </h2>
        <p class="text-neutral-500 dark:text-slate-300 mb-6 max-w-xl">
          Lideramos procesos urbanísticos completos: desde el análisis previo del
          suelo hasta la gestión administrativa y ejecución de los instrumentos de
          planeamiento.
        </p>
        <ul class="space-y-3 text-sm text-neutral-500 dark:text-slate-300 mb-8">
          <li class="flex gap-3">
            <span
              class="mt-1 size-5 flex items-center justify-center rounded-full bg-primary/10 text-primary text-xs font-bold"
              >1</span
            >
            <span>Estudios de viabilidad urbanística y estratégica de suelo.</span>
          </li>
          <li class="flex gap-3">
            <span
              class="mt-1 size-5 flex items-center justify-center rounded-full bg-primary/10 text-primary text-xs font-bold"
              >2</span
            >
            <span>Redacción y tramitación de planes generales, parciales y especiales.</span>
          </li>
          <li class="flex gap-3">
            <span
              class="mt-1 size-5 flex items-center justify-center rounded-full bg-primary/10 text-primary text-xs font-bold"
              >3</span
            >
            <span>Gestión urbanística, reparcelaciones y coordinación con administraciones.</span>
          </li>
        </ul>
        <a
          href={`${basePath}/urbanismo`}
          class="inline-flex items-center gap-2 bg-primary text-white px-7 py-3 rounded font-bold text-xs tracking-[0.2em] uppercase shadow-md shadow-primary/20 hover:bg-primary/90 transition-colors"
        >
          Ver área de urbanismo
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
      <div class="hidden lg:block">
        <div
          class="relative aspect-[4/3] rounded-xl overflow-hidden border border-slate-200 dark:border-slate-700 bg-slate-100 dark:bg-slate-900"
        >
          <div
            class="absolute inset-0 bg-cover bg-center"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBzkZ6j8cZgzRw6cxnkTVS1H4EuRg2sxJ5E4HQFeTj2P848IR4FN7m2km_PzHC8ZXR9zl6iFbBDkm02aZ_rHxuCCeIkF1XnjM3pUR-twdhULmwktvZ1UcbiO2cThBL9k_QLKwTBT7TVZAJvFY59eeN07KMrRhss8WFpvvOsQPDu61AhwnQTHrQ6zsoPk8eVwsUd9NBohDeOJKr8v4yWnYT8ee7ibVpWBLuZ3cIn95SkZoQnfnD2fYPsP6btHVaekLlQgVVQrQytbvAV')"
          ></div>
          <div
            class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"
          ></div>
          <div class="absolute bottom-5 left-5 right-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/80">
              Desarrollo urbano · Logística · Residencial
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

