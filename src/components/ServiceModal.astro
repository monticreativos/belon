---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div
  id={`modal-${id}`}
  data-modal-overlay
  class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/60 backdrop-blur-sm"
>
  <div
    class="relative mx-4 max-w-xl w-full rounded-2xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-700 shadow-2xl shadow-slate-900/40 p-6 sm:p-7 transform transition-all duration-150 ease-out"
    data-modal-panel
  >
    <button
      type="button"
      class="absolute right-4 top-4 inline-flex size-8 items-center justify-center rounded-full border border-slate-200/80 dark:border-slate-700 text-slate-400 hover:text-slate-600 dark:hover:text-slate-100 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
      data-close-modal={id}
      aria-label="Cerrar"
    >
      <span class="material-symbols-outlined text-base">close</span>
    </button>
    <h3 class="text-lg font-bold mb-3 text-neutral-700 dark:text-white">
      {title}
    </h3>
    <div class="text-sm text-neutral-500 dark:text-slate-300 space-y-3">
      <slot />
    </div>
  </div>
</div>

