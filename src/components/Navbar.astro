---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getLocaleFromPath, getPathForLocale } from "../i18n/routes";
import { getTranslations } from "../i18n";

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const t = getTranslations(locale);

const baseLinkClass =
  "text-sm font-semibold transition-colors hover:text-primary dark:text-slate-100 dark:hover:text-primary";

const isActive = (path: string) => currentPath === path;

const homeHref = locale === "en" ? "/en/" : "/";
const urbanismoHref = getPathForLocale("/urbanismo", locale);
const fiscalidadHref = getPathForLocale("/fiscalidad-inmobiliaria", locale);
const patrimonioHref = getPathForLocale("/gestion-patrimonial", locale);
const valoracionesHref = getPathForLocale("/valoraciones", locale);
const recursosHref = getPathForLocale("/recursos-administrativos", locale);
const contactoHref = getPathForLocale("/contacto", locale);
---

<nav
  class="sticky top-0 z-50 border-b border-slate-200 bg-white backdrop-blur-md dark:bg-slate-800 dark:border-slate-700"
  data-nav="main"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center py-4">
      <div class="flex items-center">
        <img
          src="/img/consultoria-belon.png"
          alt="Consultoría Belón"
          class="h-12 w-auto md:h-14"
        />
      </div>
      <div class="hidden md:flex items-center gap-6 flex-1 justify-end">
        <div class="flex items-center gap-6">
          <a
            class={`${baseLinkClass} ${isActive("/") || isActive("/en/") ? "text-primary" : "text-neutral-500"}`}
            href={homeHref}
            >{t.nav.home}</a
          >
          <a
            class={`${baseLinkClass} ${isActive("/urbanismo") || isActive("/en/urban-planning") ? "text-primary" : "text-neutral-500"}`}
            href={urbanismoHref}
          >{t.nav.urbanismo}</a>
          <a
            class={`${baseLinkClass} ${isActive("/fiscalidad-inmobiliaria") || isActive("/en/tax-advisory") ? "text-primary" : "text-neutral-500"}`}
            href={fiscalidadHref}
            >{t.nav.fiscalidad}</a
          >
          <a
            class={`${baseLinkClass} ${isActive("/gestion-patrimonial") || isActive("/en/property-management") ? "text-primary" : "text-neutral-500"}`}
            href={patrimonioHref}
            >{t.nav.patrimonio}</a
          >
          <a
            class={`${baseLinkClass} ${isActive("/valoraciones") || isActive("/en/property-valuations") ? "text-primary" : "text-neutral-500"}`}
            href={valoracionesHref}
            >{t.nav.valoraciones}</a
          >
          <a
            class={`${baseLinkClass} ${isActive("/recursos-administrativos") || isActive("/en/administrative-law") ? "text-primary" : "text-neutral-500"}`}
            href={recursosHref}
            >{t.nav.recursos}</a
          >
          <a
            class={`${baseLinkClass} ${isActive("/contacto") || isActive("/en/contact") ? "text-primary" : "text-neutral-500"}`}
            href={contactoHref}
            >{t.nav.contacto}</a
          >
        </div>
        <div class="flex items-center gap-3 ml-4">
          <LanguageSwitcher />
          <button
            type="button"
            aria-label="Cambiar tema claro/oscuro"
            class="p-2 rounded-full border border-slate-200 hover:bg-slate-50 dark:border-slate-600 dark:hover:bg-slate-700 transition-colors flex items-center justify-center bg-white/70 dark:bg-slate-800/80"
            data-theme-toggle
          >
            <span
              class="material-symbols-outlined text-slate-700 text-xl icon-light"
              >dark_mode</span
            >
            <span
              class="material-symbols-outlined text-slate-100 text-xl icon-dark"
              >light_mode</span
            >
          </button>
        </div>
      </div>
      <button class="md:hidden p-2">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>
</nav>