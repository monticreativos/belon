---
import { getTranslations } from "../i18n";
import { getPathForLocale } from "../i18n/routes";

interface Props {
  locale?: "es" | "en";
  basePath?: string;
}

const { locale = "es", basePath = "" } = Astro.props;
const t = getTranslations(locale);
const hero = (t as { hero?: Record<string, string> }).hero;
const urbanismoHref = basePath + getPathForLocale("/urbanismo", locale);
const aboutHref = basePath + (locale === "en" ? "/en/" : "/");
---

<section
  class="section-animate relative bg-white dark:bg-background-dark py-20 lg:py-28 overflow-hidden"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="max-w-2xl">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase mb-6"
        >
          <span class="material-symbols-outlined text-sm">domain</span>
          {hero?.badge ?? "Consultoría técnica integral"}
        </div>
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-black text-neutral-600 dark:text-slate-50 leading-[1.1] mb-6"
        >
          {hero?.title ?? "Arquitectura, Urbanismo y"}
          <span class="text-primary">{hero?.titleHighlight ?? "gestión inmobiliaria especializada."}</span>
        </h1>
        <p
          class="text-lg text-neutral-500 dark:text-slate-300 mb-8 leading-relaxed max-w-xl"
        >
          {hero?.description ?? "Estudio técnico con más de 25 años de experiencia acompañando a promotores, inversores y administraciones públicas en proyectos complejos de suelo, edificación y planificación urbana."}
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={urbanismoHref}
            class="bg-primary text-white px-8 py-4 rounded font-bold text-sm tracking-widest uppercase shadow-lg shadow-primary/20 hover:-translate-y-0.5 transition-transform"
          >
            {hero?.ctaUrbanismo ?? "Área de Urbanismo"}
          </a>
          <a
            href={aboutHref}
            class="border-2 border-slate-200 dark:border-slate-700 px-8 py-4 rounded font-bold text-sm tracking-widest uppercase hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
          >
            {hero?.ctaEstudio ?? "Conoce el estudio"}
          </a>
        </div>
      </div>
      <div class="relative">
        <div
          class="absolute -inset-6 bg-primary/5 rounded-3xl blur-3xl"
        ></div>
        <div
          class="relative aspect-[4/3] rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-900"
        >
          <div
            class="absolute inset-0 bg-cover bg-center"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCUn1CIuge5xFqoRaVmkuWTEMpSO0doUhyZ27LebEcpkHl2YArz3XrPBrR7P2z8mv3XeQOfdTfHpgp_9W3z7Pk9QDUbXsTESP8Z6i5indeDgx2VSVPnnHI4tl91hSj0oHdRudh6uhMdb-vdNOR9YUQo3W6CBYy6MkS77OamBSg_pxPFDPOix2kCwfuoSCrq3L61DrVPwRLS1xqWMJfodQI_NPNijdf9-laAekzq9TOynpa_Mcv96NvemuHe0S8la0eFfzeZLoDtEmyQ')"
          ></div>
          <div
            class="absolute inset-0 bg-gradient-to-tr from-black/30 via-transparent to-transparent"
          ></div>
          <div class="absolute bottom-6 left-6 right-6">
            <div
              class="inline-flex items-center gap-2 rounded-full bg-black/65 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white"
            >
              <span class="material-symbols-outlined text-sm">workspace_premium</span>
              {hero?.imageLabel ?? "Proyectos técnicos de alto impacto"}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

