---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith("/") ? base.slice(0, -1) : base;
---
<footer class="section-animate bg-neutral-900 text-white py-16 border-t border-neutral-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-12 mb-12">
      <div class="col-span-1 md:col-span-1">
        <div class="flex items-center mb-6">
          <img
            src={`${basePath}/img/consultoria-belon.png`}
            alt="Consultoría Belón"
            class="h-16 w-auto brightness-0 invert"
          />
        </div>
        <p class="text-slate-400 text-sm leading-relaxed">
          Arquitectura, Urbanismo y Gestión estratégica de proyectos inmobiliarios
          de alto impacto.
        </p>
      </div>

      <div>
        <h5
          class="font-bold text-xs tracking-widest uppercase mb-6 text-primary"
        >
          Navegación
        </h5>
        <ul class="space-y-4 text-sm text-slate-400">
          <li>
            <a href={`${basePath}/`} class="hover:text-white transition-colors">Inicio</a>
          </li>
          <li>
            <a href={`${basePath}/urbanismo`} class="hover:text-white transition-colors"
              >Urbanismo</a
            >
          </li>
          <li>
            <a
              href={`${basePath}/fiscalidad-inmobiliaria`}
              class="hover:text-white transition-colors"
              >Fiscalidad</a
            >
          </li>
          <li>
            <a
              href={`${basePath}/gestion-patrimonial`}
              class="hover:text-white transition-colors"
              >Patrimonio</a
            >
          </li>
          <li>
            <a href={`${basePath}/valoraciones`} class="hover:text-white transition-colors"
              >Valoraciones</a
            >
          </li>
          <li>
            <a
              href={`${basePath}/recursos-administrativos`}
              class="hover:text-white transition-colors"
              >Recursos</a
            >
          </li>
          <li>
            <a href={`${basePath}/contacto`} class="hover:text-white transition-colors"
              >Contacto</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h5
          class="font-bold text-xs tracking-widest uppercase mb-6 text-primary"
        >
          Servicios
        </h5>
        <ul class="space-y-4 text-sm text-slate-400">
          <li>
            <span>Urbanismo y gestión del suelo</span>
          </li>
          <li>
            <span>Fiscalidad inmobiliaria</span>
          </li>
          <li>
            <span>Gestión patrimonial</span>
          </li>
          <li>
            <span>Valoraciones y recursos administrativos</span>
          </li>
        </ul>
      </div>

      <div>
        <h5
          class="font-bold text-xs tracking-widest uppercase mb-6 text-primary"
        >
          Contacto
        </h5>
        <p class="text-sm text-slate-400 mb-4">
          Calle Principal, 12, Planta 4<br />
          29000 Málaga, España
        </p>
        <p class="text-sm text-slate-400">+34 952 00 00 00</p>
        <p class="text-sm text-slate-400">contacto@belon.com</p>
      </div>
    </div>

    <div
      class="pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500 font-medium tracking-wide"
    >
      <p>© 2024 CONSULTORÍA BELÓN. TODOS LOS DERECHOS RESERVADOS.</p>
      <div class="flex gap-8">
        <a href={`${basePath}/aviso-legal`} class="hover:text-white transition-colors"
          >Aviso legal</a
        >
        <a href={`${basePath}/politica-privacidad`} class="hover:text-white transition-colors"
          >Política de privacidad</a
        >
        <a href={`${basePath}/politica-cookies`} class="hover:text-white transition-colors"
          >Política de cookies</a
        >
        <button
          type="button"
          data-cookie-manage
          class="hover:text-white transition-colors underline underline-offset-4 decoration-slate-500/80"
        >
          Configurar cookies
        </button>
      </div>
    </div>
  </div>
</footer>